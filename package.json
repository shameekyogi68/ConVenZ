{
  "name": "convenz-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Premium Monorepo for ConVenZ Customer and Backend",
  "scripts": {
    "install:backend": "cd backend && npm install",
    "start:backend": "cd backend && npm start",
    "dev:backend": "cd backend && npm run dev",
    "clean:frontend": "cd frontend && flutter clean",
    "get:frontend": "cd frontend && flutter pub get",
    "build:apk": "cd frontend && flutter build apk --release",
    "setup:all": "npm run install:backend && npm run get:frontend"
  }
}
