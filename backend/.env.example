# Server Configuration
PORT=5005
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/Convenz

# External API Keys (Geocoding)
OPENCAGE_API_KEY=your_opencage_api_key_here

# Firebase Configuration
# Path to your Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# OR provide direct JSON string (useful for platforms like Render/Heroku)
# FIREBASE_CONFIG_JSON={"type": "service_account", ...}

# External Vendor URLs
EXTERNAL_VENDOR_URL=https://convenz-vendor-dor.vercel.app/api/external/orders
WEBSERVER_VENDOR_URL=https://webserver-vendor.vercel.app/api/external/orders
VENDOR_BACKEND_URL=https://vendor-backend-7cn3.onrender.com

# 🔐 Security Secrets (Rotate these for production!)
JWT_SECRET=convenz_super_secret_jwt_key_2026
ADMIN_SECRET=convenz_admin_dashboard_secret_2026
SERVER_SECRET=convenz_server_to_server_secret_2026
VENDOR_SECRET=vendor-secret-key-2024
WEBSERVER_VENDOR_SECRET=webserver-vendor-secret-key-2024
CRON_SECRET=nudge_trigger_secret_2026
API_SIGNING_SECRET=convenz_default_secret_key_2024_@!

# Session Settings
SESSION_EXPIRY=30d

# 🌐 CORS Configuration
# Comma-separated list (e.g. http://localhost:3000,https://myweb.app)
ALLOWED_ORIGINS=http://localhost:3000

# Instructions:
# 1. Copy this file as .env in the backend root directory
# 2. Replace placeholder values with your actual configuration
# 3. Never commit the .env file to version control
